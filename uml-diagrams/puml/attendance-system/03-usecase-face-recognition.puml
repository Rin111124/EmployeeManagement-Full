@startuml
title Use case chi tiet - Face Recognition
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle

actor Employee
actor "Kiosk Terminal" as Kiosk
actor "HR Admin" as Admin

rectangle "Face Recognition" {
  usecase "Register Face" as UC_Register
  usecase "Recognize Face" as UC_Recognize
  usecase "Update Face" as UC_Update
  usecase "Delete Face" as UC_Delete
  usecase "View Face Log" as UC_ViewLog
}

Kiosk --> UC_Register
Kiosk --> UC_Recognize
Admin --> UC_Update
Admin --> UC_Delete
Admin --> UC_ViewLog
Employee --> UC_ViewLog

@enduml
