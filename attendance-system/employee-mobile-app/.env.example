# Public Expo configuration for the employee mobile app.
# Copy this file to .env and keep .env out of version control.
#
# These EXPO_PUBLIC_* values are bundled into the mobile app.
# Do not put API keys, JWTs, refresh tokens, database URLs, or passwords here.

# Optional shared host. Used only when EXPO_PUBLIC_ADMIN_URL is empty.
EXPO_PUBLIC_API_HOST=192.168.1.25

# Admin backend API endpoint reachable from the phone/emulator.
EXPO_PUBLIC_ADMIN_URL=http://192.168.1.25:5000/api/v1
