# Public Expo configuration for the kiosk app.
# Copy this file to .env and keep .env out of version control.
#
# These EXPO_PUBLIC_* values are bundled into the mobile app.
# Do not put API keys, JWTs, device tokens, database URLs, or passwords here.

# Optional shared host. Used only when the specific URLs below are empty.
EXPO_PUBLIC_API_HOST=192.168.1.25

# Service endpoints reachable from the phone/emulator.
EXPO_PUBLIC_ADMIN_URL=http://192.168.1.25:5000
EXPO_PUBLIC_AI_SERVICE_URL=http://192.168.1.25:8000
EXPO_PUBLIC_ATTENDANCE_URL=http://192.168.1.25:5001/api

# Security note:
# AI_API_KEY must not be stored in Expo public env variables. Prefer calling AI
# through a trusted backend, or enter a short-lived key at runtime if needed.
