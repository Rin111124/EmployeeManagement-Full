# ============================================================
# Docker Compose Environment Variables Template
# Copy this file to .env.docker and fill in real values.
# NEVER commit .env.docker to version control.
# ============================================================

# ---- MongoDB ----
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change-me-strong-password

# ---- Admin Backend ----
JWT_SECRET=replace-with-at-least-64-random-chars
JWT_ACCESS_SECRET=replace-with-at-least-64-random-access-chars
JWT_REFRESH_SECRET=replace-with-at-least-64-random-refresh-chars
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000
VITE_API_BASE=http://localhost:5000/api/v1
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
CHATBOT_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# ---- Attendance Service ----
SYNC_SECRET=replace-with-at-least-32-random-chars

# ---- AI Service ----
AI_API_KEY=replace-with-a-random-api-key-for-ai-service
